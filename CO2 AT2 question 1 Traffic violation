#include &lt;iostream&gt;
using namespace std;

class Violation {
private:
string vehicleNo, ownerName, violationType;
int fineAmount;

public:
static int totalViolations;

void input() {
cout &lt;&lt; &quot;Enter Vehicle Number: &quot;;
cin &gt;&gt; vehicleNo;

cout &lt;&lt; &quot;Enter Owner Name: &quot;;
cin &gt;&gt; ownerName;

cout &lt;&lt; &quot;Enter Violation Type (Speed/Signal/Parking): &quot;;
cin &gt;&gt; violationType;

if (violationType == &quot;Speed&quot;)
fineAmount = 1000;
else if (violationType == &quot;Signal&quot;)
fineAmount = 1500;
else if (violationType == &quot;Parking&quot;)
fineAmount = 500;
else {
cout &lt;&lt; &quot;Invalid violation type!\n&quot;;
fineAmount = 0;

}

if (fineAmount &gt; 0)
totalViolations++;
}

void display() {
cout &lt;&lt; &quot;\nVehicle No: &quot; &lt;&lt; vehicleNo;
cout &lt;&lt; &quot;\nOwner Name: &quot; &lt;&lt; ownerName;
cout &lt;&lt; &quot;\nViolation Type: &quot; &lt;&lt; violationType;
cout &lt;&lt; &quot;\nFine Amount: Rs.&quot; &lt;&lt; fineAmount &lt;&lt; endl;
}
};

int Violation::totalViolations = 0;

int main() {
int n;
cout &lt;&lt; &quot;Enter number of violation records: &quot;;
cin &gt;&gt; n;

Violation v[50];

for (int i = 0; i &lt; n; i++) {
cout &lt;&lt; &quot;\nEnter details for violation &quot; &lt;&lt; i + 1 &lt;&lt; endl;
v[i].input();
}

cout &lt;&lt; &quot;\n--- Violation Reports ---\n&quot;;
for (int i = 0; i &lt; n; i++) {
v[i].display();

}

cout &lt;&lt; &quot;\nTotal Violations Recorded: &quot; &lt;&lt; Violation::totalViolations;

return 0;
}
