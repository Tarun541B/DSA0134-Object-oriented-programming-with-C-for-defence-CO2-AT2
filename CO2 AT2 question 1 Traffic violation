#include <iostream>
using namespace std;

class Violation {
private:
    string vehicleNo, ownerName, violationType;
    int fineAmount;

public:
    static int totalViolations;

    void input() {
        cout << "Enter Vehicle Number: ";
        cin >> vehicleNo;

        cout << "Enter Owner Name: ";
        cin >> ownerName;

        cout << "Enter Violation Type (Speed/Signal/Parking): ";
        cin >> violationType;

        if (violationType == "Speed")
            fineAmount = 1000;
        else if (violationType == "Signal")
            fineAmount = 1500;
        else if (violationType == "Parking")
            fineAmount = 500;
        else {
            cout << "Invalid violation type!\n";
            fineAmount = 0;
        }

        if (fineAmount > 0)
            totalViolations++;
    }

    void display() {
        cout << "\nVehicle No: " << vehicleNo;
        cout << "\nOwner Name: " << ownerName;
        cout << "\nViolation Type: " << violationType;
        cout << "\nFine Amount: Rs." << fineAmount << endl;
    }
};

int Violation::totalViolations = 0;

int main() {
    int n;
    cout << "Enter number of violation records: ";
    cin >> n;

    Violation v[50];

    for (int i = 0; i < n; i++) {
        cout << "\nEnter details for violation " << i + 1 << endl;
        v[i].input();
    }

    cout << "\n--- Violation Reports ---\n";
    for (int i = 0; i < n; i++) {
        v[i].display();
    }

    cout << "\nTotal Violations Recorded: " << Violation::totalViolations;

    return 0;
}
 
