#include <iostream>
using namespace std;

class Event {
private:
    string eventName, participantName;
    int registrationID;

public:
    static int totalParticipants;

    void input(Event e[], int count) {
        cout << "Enter Event Name: ";
        cin >> eventName;

        cout << "Enter Participant Name: ";
        cin >> participantName;

        cout << "Enter Registration ID: ";
        cin >> registrationID;

        for (int i = 0; i < count; i++) {
            if (e[i].registrationID == registrationID) {
                cout << "Duplicate Registration ID not allowed!\n";
                registrationID = 0;
                return;
            }
        }

        totalParticipants++;
    }
    void display() {
        if (registrationID != 0) {
            cout << "\nEvent Name: " << eventName;
            cout << "\nParticipant Name: " << participantName;
            cout << "\nRegistration ID: " << registrationID << endl;
        }
    }
};
int Event::totalParticipants = 0;
int main() {
    int n;
    cout << "Enter number of registrations: ";
    cin >> n;
    Event e[50];
    for (int i = 0; i < n; i++) {
        cout << "\nEnter registration " << i + 1 << " details\n";
        e[i].input(e, i);
    }
    cout << "\n--- Event Registration Details ---\n";
    for (int i = 0; i < n; i++) {
        e[i].display();
    }
    cout << "\nTotal Participants: " << Event::totalParticipants;
    return 0;
}
