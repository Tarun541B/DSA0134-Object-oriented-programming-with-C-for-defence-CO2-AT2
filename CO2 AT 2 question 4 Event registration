#include <iostream>
using namespace std;

class Event {
private:
string eventName, participantName;
int registrationID;

public:
static int totalParticipants;

void input(Event e[], int count) {
cout &lt;&lt; &quot;Enter Event Name: &quot;;
cin &gt;&gt; eventName;

cout &lt;&lt; &quot;Enter Participant Name: &quot;;
cin &gt;&gt; participantName;

cout &lt;&lt; &quot;Enter Registration ID: &quot;;
cin &gt;&gt; registrationID;

for (int i = 0; i &lt; count; i++) {
if (e[i].registrationID == registrationID) {
cout &lt;&lt; &quot;Duplicate Registration ID not allowed!\n&quot;;
registrationID = 0;
return;
}
}

totalParticipants++;
}
void display() {
if (registrationID != 0) {
cout &lt;&lt; &quot;\nEvent Name: &quot; &lt;&lt; eventName;
cout &lt;&lt; &quot;\nParticipant Name: &quot; &lt;&lt; participantName;
cout &lt;&lt; &quot;\nRegistration ID: &quot; &lt;&lt; registrationID &lt;&lt; endl;
}
}
};
int Event::totalParticipants = 0;
int main() {
int n;
cout &lt;&lt; &quot;Enter number of registrations: &quot;;
cin &gt;&gt; n;
Event e[50];
for (int i = 0; i &lt; n; i++) {
cout &lt;&lt; &quot;\nEnter registration &quot; &lt;&lt; i + 1 &lt;&lt; &quot; details\n&quot;;
e[i].input(e, i);
}
cout &lt;&lt; &quot;\n--- Event Registration Details ---\n&quot;;
for (int i = 0; i &lt; n; i++) {
e[i].display();
}
cout &lt;&lt; &quot;\nTotal Participants: &quot; &lt;&lt; Event::totalParticipants;
return 0;
}
