#include <iostream>
using namespace std;

class Product {
private:
    string productName;
    float price;
    int quantity;

public:
    static int totalProducts;

    void getData() {
        cout << "Enter Product Name: ";
        cin >> productName;

        cout << "Enter Price: ";
        cin >> price;

        cout << "Enter Quantity: ";
        cin >> quantity;

        if (price <= 0 || quantity <= 0) {
            cout << "Invalid price or quantity!\n";
            price = 0;
            quantity = 0;
        } else {
            totalProducts++;
        }
    }

    float calculateTotal() {
        return price * quantity;
    }

    void display() {
        cout << "\nProduct Name: " << productName;
        cout << "\nPrice: Rs." << price;
        cout << "\nQuantity: " << quantity;
        cout << "\nTotal: Rs." << calculateTotal() << endl;
    }
};

int Product::totalProducts = 0;

int main() {
    int n;
    float totalBill = 0;

    cout << "Enter number of products: ";
    cin >> n;

    Product p[50];

    for (int i = 0; i < n; i++) {
        cout << "\nEnter product " << i + 1 << " details\n";
        p[i].getData();
    }

    cout << "\n--- Shopping Cart Details ---\n";
    for (int i = 0; i < n; i++) {
        p[i].display();
        totalBill += p[i].calculateTotal();
    }

    cout << "\nTotal Products: " << Product::totalProducts;
    cout << "\nTotal Bill: Rs." << totalBill;

    return 0;
}
